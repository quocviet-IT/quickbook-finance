# Supabase project: ctyhp-accounting
# Copy to .env.local and fill in from the Supabase dashboard (Project Settings > API).

# Public (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — NEVER expose to the browser, NEVER commit the real value.
# Used only for administrative/seed scripts, not in request handlers.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
